<Window
    x:Class="CodeCafe.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CodeCafe"
    Width="1280"
    Height="780"
    MinWidth="980"
    MinHeight="640"
    Background="#F4F6F8"
    x:CompileBindings="False"
    mc:Ignorable="d">
  <Grid ColumnDefinitions="248,*,336" RowDefinitions="72,*">
    <Border Grid.RowSpan="2" Background="#1D2733" Padding="22">
      <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel>
          <TextBlock
              FontSize="22"
              FontWeight="SemiBold"
              Foreground="#FFFFFF"
              Text="CodeCafe" />
          <TextBlock
              Margin="0,4,0,0"
              FontSize="12"
              Foreground="#AEB8C4"
              Text="Desktop workspace" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,28,0,22"
            Padding="14"
            Background="#263544"
            BorderBrush="#3C4D5E"
            BorderThickness="1"
            CornerRadius="8">
          <StackPanel Spacing="6">
            <TextBlock
                FontSize="11"
                Foreground="#AEB8C4"
                Text="Current Workspace" />
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="#FFFFFF"
                Text="{Binding CurrentWorkspaceDisplayName}"
                TextWrapping="Wrap" />
            <TextBlock
                FontSize="12"
                Foreground="#8FDBD4"
                Text="{Binding CurrentWorkspaceId}"
                TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <ListBox
            Grid.Row="2"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#E5EBF2"
            ItemsSource="{Binding NavigationItems}"
            SelectedItem="{Binding SelectedNavigationItem}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Padding="10,9" Text="{Binding}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border
        Grid.Column="1"
        Grid.ColumnSpan="2"
        Padding="28,14"
        Background="#FFFFFF"
        BorderBrush="#DDE4EC"
        BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock
              FontSize="13"
              Foreground="#64748B"
              Text="{Binding SelectedNavigationItem}" />
          <TextBlock
              FontSize="22"
              FontWeight="SemiBold"
              Foreground="#17202A"
              Text="{Binding CurrentWorkspaceDisplayName}"
              TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border
            Grid.Column="1"
            VerticalAlignment="Center"
            Padding="12,7"
            Background="#E8F6F5"
            BorderBrush="#B8E2DE"
            BorderThickness="1"
            CornerRadius="8">
          <TextBlock
              FontSize="12"
              FontWeight="SemiBold"
              Foreground="#126B63"
              Text="{Binding WorkspaceLoadStatus}" />
        </Border>
      </Grid>
    </Border>

    <Border
        Grid.Row="1"
        Grid.Column="1"
        Margin="28,24,16,24"
        Padding="28"
        Background="#FFFFFF"
        BorderBrush="#DDE4EC"
        BorderThickness="1"
        CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#17202A"
            Text="{Binding CurrentWorkspaceDisplayName}"
            TextWrapping="Wrap" />
        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,22"
            FontSize="14"
            Foreground="#526173"
            Text="{Binding CurrentWorkspaceDescription}"
            TextWrapping="Wrap" />

        <Grid Grid.Row="2" ColumnDefinitions="*,*" RowDefinitions="Auto,*">
          <TextBlock
              FontSize="13"
              FontWeight="SemiBold"
              Foreground="#526173"
              Text="Workspace Surface" />
          <TextBlock
              Grid.Column="1"
              FontSize="13"
              FontWeight="SemiBold"
              Foreground="#526173"
              Text="Entry Context" />

          <Border
              Grid.Row="1"
              Margin="0,12,12,0"
              Padding="18"
              Background="#F8FAFC"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="8">
            <StackPanel Spacing="14">
              <TextBlock
                  FontSize="18"
                  FontWeight="SemiBold"
                  Foreground="#17202A"
                  Text="Workspace Home" />
              <TextBlock
                  FontSize="13"
                  Foreground="#526173"
                  Text="Notes, code context, activity, and project lanes will attach to this current workspace."
                  TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border
              Grid.Row="1"
              Grid.Column="1"
              Margin="12,12,0,0"
              Padding="18"
              Background="#FFF8E8"
              BorderBrush="#F0DFAF"
              BorderThickness="1"
              CornerRadius="8">
            <StackPanel Spacing="10">
              <TextBlock
                  FontSize="18"
                  FontWeight="SemiBold"
                  Foreground="#17202A"
                  Text="Current Workspace" />
              <TextBlock
                  FontSize="13"
                  Foreground="#6C5A22"
                  Text="{Binding CurrentWorkspaceId}"
                  TextWrapping="Wrap" />
              <TextBlock
                  FontSize="12"
                  Foreground="#7A6B3A"
                  Text="{Binding LastLoadedAt}" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <Border
        Grid.Row="1"
        Grid.Column="2"
        Margin="0,24,24,24"
        Padding="22"
        Background="#FCFCFD"
        BorderBrush="#DDE4EC"
        BorderThickness="1"
        CornerRadius="8">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="#17202A"
            Text="AI / Context" />
        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,18"
            FontSize="13"
            Foreground="#526173"
            Text="Workspace-aware AI surface placeholder"
            TextWrapping="Wrap" />

        <StackPanel Grid.Row="2" Spacing="14">
          <Border
              Padding="16"
              Background="#F0F7FF"
              BorderBrush="#C8DBF3"
              BorderThickness="1"
              CornerRadius="8">
            <StackPanel Spacing="8">
              <TextBlock
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="#23466D"
                  Text="Context Scope" />
              <TextBlock
                  FontSize="13"
                  Foreground="#526173"
                  Text="{Binding CurrentWorkspaceDisplayName}"
                  TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border
              Padding="16"
              Background="#F8FAFC"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="8">
            <StackPanel Spacing="8">
              <TextBlock
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="#526173"
                  Text="Integration Status" />
              <TextBlock
                  FontSize="13"
                  Foreground="#526173"
                  Text="Awaiting AI module and live workspace context integration."
                  TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
